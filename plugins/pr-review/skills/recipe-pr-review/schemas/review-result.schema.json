{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PR Review Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "confidence",
    "summary",
    "inspected",
    "quality_coverage",
    "inline_comments",
    "overall_comments",
    "suppressed_prior_comments",
    "notes"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["COMMENT", "APPROVE"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "inspected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quality_standard",
        "project_guidance",
        "changed_files",
        "prior_comments_considered"
      ],
      "properties": {
        "quality_standard": {
          "type": "string",
          "minLength": 1
        },
        "project_guidance": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "changed_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prior_comments_considered": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "quality_coverage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "criterion",
          "changed_surface",
          "evidence_checked"
        ],
        "properties": {
          "criterion": {
            "type": "string",
            "minLength": 1
          },
          "changed_surface": {
            "type": "string",
            "minLength": 1
          },
          "evidence_checked": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "inline_comments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "line",
          "side",
          "severity",
          "title",
          "body",
          "evidence",
          "failure_scenario",
          "suggested_fix"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "side": {
            "type": "string",
            "enum": ["RIGHT", "LEFT"]
          },
          "severity": {
            "type": "string",
            "enum": ["must", "should", "question", "nit"]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": ["string", "null"]
          },
          "failure_scenario": {
            "type": ["string", "null"]
          },
          "suggested_fix": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "overall_comments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "title",
          "body",
          "paths",
          "evidence",
          "failure_scenario",
          "suggested_fix"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["must", "should", "question", "nit"]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string",
            "minLength": 1
          },
          "paths": {
            "type": ["array", "null"],
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evidence": {
            "type": ["string", "null"]
          },
          "failure_scenario": {
            "type": ["string", "null"]
          },
          "suggested_fix": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "suppressed_prior_comments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "reason"],
        "properties": {
          "source": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
